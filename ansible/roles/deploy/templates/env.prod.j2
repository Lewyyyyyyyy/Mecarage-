# MecaManage — Variables d'environnement Production
FRONTEND_IMAGE={{ frontend_image }}
BACKEND_IMAGE={{ backend_image }}
IA_SERVICE_IMAGE={{ ia_service_image }}

MYSQL_DATABASE={{ mysql_database }}
MYSQL_ROOT_PASSWORD={{ mysql_root_password }}
MYSQL_ROOT_HOST={{ mysql_root_host }}

CONNECTION_STRING=Server=mysql;Port=3306;Database={{ mysql_database }};User=root;Password={{ mysql_root_password }};SslMode=None;AllowPublicKeyRetrieval=True
REDIS_CONNECTION=redis:6379
JWT_SECRET={{ jwt_secret }}
JWT_ISSUER=MecaManage
JWT_AUDIENCE=MecaManageClients
JWT_EXPIRY_MINUTES=60

GEMINI_API_KEY={{ gemini_api_key }}
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_SECONDS=0.2

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER={{ n8n_basic_auth_user }}
N8N_BASIC_AUTH_PASSWORD={{ n8n_basic_auth_password }}
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}
N8N_DATABASE={{ n8n_database }}

GRAFANA_ADMIN_USER={{ grafana_admin_user }}
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password }}
GRAFANA_SMTP_ENABLED={{ grafana_smtp_enabled }}
GRAFANA_SMTP_HOST={{ grafana_smtp_host }}
GRAFANA_SMTP_USER={{ grafana_smtp_user }}
GRAFANA_SMTP_PASSWORD={{ grafana_smtp_password }}
GRAFANA_SMTP_FROM_ADDRESS={{ grafana_smtp_from_address }}
GRAFANA_SMTP_FROM_NAME={{ grafana_smtp_from_name }}
