# MecaManage — Variables d'environnement Production
POSTGRES_DB=mecamanage
POSTGRES_USER=mecamanage_user
POSTGRES_PASSWORD={{ postgres_password }}

CONNECTION_STRING=Host=postgres;Port=5432;Database=mecamanage;Username=mecamanage_user;Password={{ postgres_password }}
REDIS_CONNECTION=redis:6379
JWT_SECRET={{ jwt_secret }}
JWT_ISSUER=MecaManage
JWT_AUDIENCE=MecaManageClients
JWT_EXPIRY_MINUTES=60

GEMINI_API_KEY={{ gemini_api_key }}
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_SECONDS=0.2

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123