  usecase "Consulter Tâches" as UC08
  usecase "Rapport d'Examen" as UC09
  usecase "Fin de Réparation" as UC10
  usecase "Réviser Rapport Symptômes" as UC11
  usecase "Gérer Rendez-vous" as UC12
  usecase "Assigner Mécaniciens" as UC13
  usecase "Créer Facture / Devis" as UC14
  usecase "Valider et Notifier" as UC15
  usecase "Gérer Garages et Personnel" as UC16
  usecase "Gérer Pièces Détachées" as UC17
  usecase "Enregistrer Paiement" as UC18
  usecase "Gérer Tenants" as UC19
