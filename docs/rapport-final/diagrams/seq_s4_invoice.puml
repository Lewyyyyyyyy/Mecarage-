@startuml seq_s4_invoice
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam SequenceParticipantBorderColor #1D4ED8
skinparam SequenceParticipantBackgroundColor #2563EB
skinparam SequenceParticipantFontColor #FFFFFF
skinparam SequenceParticipantFontStyle bold
skinparam SequenceActorBorderColor #1D4ED8
skinparam SequenceActorBackgroundColor #DBEAFE
skinparam SequenceArrowColor #374151
skinparam SequenceArrowThickness 1.5
skinparam SequenceLifeLineBorderColor #93C5FD
skinparam SequenceGroupBorderColor #1D4ED8
skinparam SequenceGroupBackgroundColor #EFF6FF
skinparam SequenceGroupFontColor #1E3A8A
skinparam NoteBackgroundColor #FFFBEB
skinparam NoteBorderColor #F59E0B
skinparam TitleFontSize 13
skinparam TitleFontStyle bold

title SC6 — Finalisation Facture + Approbation Client (US19+US20) — Sprint 4

actor ":ChefAtelier" as chef
participant ":InvoicesController" as ictrl
participant ":FinalizeInvoiceHandler" as fhand
database ":Database" as db
participant ":NotificationService" as notif
actor ":Client" as cli

group Phase 1 : Chef finalise le devis
  chef -> ictrl : PATCH /api/invoices/{id}/finalize
  activate ictrl
  ictrl -> fhand : Handle(FinalizeInvoiceCommand)
  activate fhand
  fhand -> db : GetInvoice(id)
  activate db
  db --> fhand : Invoice
  deactivate db
  fhand -> fhand : Status = AwaitingApproval
  fhand -> db : UpdateIntervention(InvoicePending)
  activate db
  db --> fhand : OK
  deactivate db
  fhand -> notif : Notify(clientId, "Devis disponible")
  activate notif
  notif -> db : Add(notification)
  activate db
  db --> notif : OK
  deactivate db
  deactivate notif
  fhand --> ictrl : OK
  deactivate fhand
  ictrl --> chef : 200 OK
  deactivate ictrl
end

notif -> cli : Push notification : "Devis à approuver"

group Phase 2 : Client approuve
  cli -> ictrl : POST /api/invoices/{id}/approve
  activate ictrl
  ictrl -> fhand : Handle(ApproveInvoiceCommand)
  activate fhand
  fhand -> fhand : clientApproved = true
  fhand -> db : UpdateIntervention(RepairInProgress); SaveChanges()
  activate db
  db --> fhand : OK
  deactivate db
  fhand --> ictrl : OK
  deactivate fhand
  ictrl --> cli : 200 OK {status: Approved}
  deactivate ictrl
end

@enduml

