# ============================================================
# MecaManage — Docker Compose Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Docker images ─────────────────────────────────────────────
FRONTEND_IMAGE=mecamanage-frontend:local
BACKEND_IMAGE=mecamanage-backend:local
IA_SERVICE_IMAGE=mecamanage-ia:local

# ── MySQL ────────────────────────────────────────────────────
MYSQL_DATABASE=mecamanage
MYSQL_ROOT_PASSWORD=iheb
MYSQL_ROOT_HOST=%

# ── Backend connection strings ───────────────────────────────
CONNECTION_STRING=Server=mysql;Port=3306;Database=mecamanage;User=root;Password=iheb;SslMode=None;AllowPublicKeyRetrieval=True
REDIS_CONNECTION=redis:6379

# ── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=MecaManage_Super_Secret_Key_2026_MinLength32Chars!
JWT_ISSUER=MecaManage
JWT_AUDIENCE=MecaManageClients
JWT_EXPIRY_MINUTES=60

# ── Google Gemini AI ─────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_SECONDS=2

# ── n8n Workflow Automation ──────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_n8n_encryption_key_32_chars_min
N8N_DATABASE=n8n

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
GRAFANA_SMTP_ENABLED=true
GRAFANA_SMTP_HOST=smtp.gmail.com:587
GRAFANA_SMTP_USER=your_email@gmail.com
GRAFANA_SMTP_PASSWORD=change_me_app_password
GRAFANA_SMTP_FROM_ADDRESS=your_email@gmail.com
GRAFANA_SMTP_FROM_NAME=MecaManage Monitoring
