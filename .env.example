# ══════════════════════════════════════════════════════════════
# MecaManage Environment Variables
# Copy this file to .env and update values for your environment
# ══════════════════════════════════════════════════════════════

# ── MySQL Configuration ──────────────────────────────────────
MYSQL_DATABASE=mecarage
MYSQL_ROOT_PASSWORD=iheb
MYSQL_ROOT_HOST=%
CONNECTION_STRING="Server=mysql;Port=3306;Database=mecarage;Uid=root;Pwd=iheb;"

# ── JWT Configuration ────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production-here-with-at-least-32-chars
JWT_ISSUER=mecamanage
JWT_AUDIENCE=mecamanage-api
JWT_EXPIRY_MINUTES=60

# ── Docker Images ────────────────────────────────────────────
BACKEND_IMAGE=mecamanage-backend:latest
FRONTEND_IMAGE=mecamanage-frontend:latest

# ── API Configuration ────────────────────────────────────────
API_URL=http://localhost:5000
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Production

# ── Frontend Configuration ───────────────────────────────────
FRONTEND_PORT=3000
FRONTEND_BUILD_MODE=production

# ── NGINX Configuration ──────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443

