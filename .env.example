# ─────────────────────────────────────────────────────────
#  MecaRage — Environment Variables Template
#  Copy this file to .env and fill in your own values.
#  NEVER commit your real .env file.
# ─────────────────────────────────────────────────────────

# ── MySQL ────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mecamanage
MYSQL_USER=root
MYSQL_PASSWORD=root

# Full connection string used by ASP.NET Core
# (env vars with __ override appsettings.json keys)
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=mecamanage;User=root;Password=root

# ── Redis ─────────────────────────────────────────────────
ConnectionStrings__Redis=localhost:6379

# ── JWT ───────────────────────────────────────────────────
Jwt__Secret=MecaManage_Super_Secret_Key_2026_MinLength32Chars!
Jwt__Issuer=MecaManage
Jwt__Audience=MecaManageClients
Jwt__ExpiryMinutes=60

# ── Bootstrap Super Admin (first run only) ────────────────
BootstrapSuperAdmin__Email=admin@mecamanage.local
BootstrapSuperAdmin__Password=SuperAdmin@123
