# ═══════════════════════════════════════════════════════════════
# MECARAGE - Environment Configuration Template
# Copy to .env and fill in your values
# ⚠️ NEVER commit your real .env file to Git!
# ═══════════════════════════════════════════════════════════════

# ─ DATABASE (MySQL) ─────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=mecarage
MYSQL_ROOT_PASSWORD=iheb
MYSQL_USER=mecamanage_user
MYSQL_PASSWORD=pass123
MYSQL_ROOT_HOST=%

# Full connection string for ASP.NET Core
ConnectionStrings__DefaultConnection=Server=mysql;Port=3306;Database=mecarage;User=root;Password=iheb;

# ─ REDIS ────────────────────────────────────────────────────
ConnectionStrings__Redis=redis:6379
REDIS_PASSWORD=

# ─ JWT SECURITY ─────────────────────────────────────────────
Jwt__Secret=MecaManage_Super_Secret_Key_2026_MinLength32Chars!
Jwt__Issuer=MecaManage
Jwt__Audience=MecaManageClients
Jwt__ExpiryMinutes=60

# ─ BOOTSTRAP SUPER ADMIN (created on first run) ──────────────
BootstrapSuperAdmin__Email=admin@mecamanage.local
BootstrapSuperAdmin__Password=SuperAdmin@123

# ─ AI SERVICE (Gemini) ──────────────────────────────────────
GEMINI_API_KEY=your_google_api_key_here
GROQ_API_KEY=

# ─ DOCKER IMAGES ────────────────────────────────────────────
BACKEND_IMAGE=mecamanage-backend:latest
FRONTEND_IMAGE=mecamanage-frontend:latest

# ─ PORTS ────────────────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=3000
MYSQL_PORT=3306
REDIS_PORT=6379

# ─ DOCKER HUB (for CI/CD) ──────────────────────────────────
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_REGISTRY=docker.io

# ─ GITHUB REGISTRY ──────────────────────────────────────────
GHCR_USERNAME=
GHCR_TOKEN=

# ─ ENVIRONMENT MODE ────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
NODE_ENV=production
PYTHON_ENV=production

# ─ LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=Information
DEBUG=false

# ─ PRODUCTION DEPLOYMENT (optional) ────────────────────────
# SERVER_HOST=your-server-ip-or-domain
# SERVER_USER=deployer
# SERVER_SSH_KEY=your-private-key

